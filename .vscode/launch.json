{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "启动 API 服务",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8",
                "STRATEGY_STUDIO_DATABASE_URL": "postgresql+psycopg://postgres:tian@localhost:5432/etf_strategy"
            },
            "args": [
                "api",
                "--host",
                "127.0.0.1",
                "--port",
                "8000",
                "--replace-existing"
            ]
        },
        {
            "name": "启动后台任务 Worker",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8",
                "STRATEGY_STUDIO_DATABASE_URL": "postgresql+psycopg://postgres:tian@localhost:5432/etf_strategy"
            },
            "args": [
                "worker",
                "--poll-interval",
                "5"
            ]
        },
        {
            "name": "启动行情 Scheduler",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8",
                "STRATEGY_STUDIO_DATABASE_URL": "postgresql+psycopg://postgres:tian@localhost:5432/etf_strategy"
            },
            "args": [
                "scheduler"
            ]
        },
        {
            "name": "启动前端 Dev Server",
            "type": "node-terminal",
            "request": "launch",
            "command": "npx next dev --hostname 127.0.0.1 --port 3000",
            "cwd": "${workspaceFolder}/frontend",
            "env": {
                "STRATEGY_STUDIO_API_ORIGIN": "http://127.0.0.1:8000"
            }
        },
        {
            "name": "执行 A 股统一补数链路",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8",
                "STRATEGY_STUDIO_DATABASE_URL": "postgresql+psycopg://postgres:tian@localhost:5432/etf_strategy"
            },
            "args": [
                "sync-now",
                "--provider",
                "tdx_pipeline",
                "--symbol",
                "sh600000",
                "--interval",
                "all",
                "--force"
            ]
        }
    ],
    "compounds": [
        {
            "name": "启动平台后端全套",
            "configurations": [
                "启动 API 服务",
                "启动后台任务 Worker",
                "启动行情 Scheduler"
            ]
        },
        {
            "name": "启动平台前后端全套",
            "configurations": [
                "启动前端 Dev Server",
                "启动 API 服务",
                "启动后台任务 Worker",
                "启动行情 Scheduler"
            ]
        }
    ]
}
