{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "一键生成日线正式报告",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "redirectOutput": true,
            "justMyCode": true,
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8"
            },
            "args": [
                "report",
                "--data",
                "data/processed/1810_hk_daily.csv",
                "--symbol",
                "1810.HK"
            ]
        },
        {
            "name": "一键生成15分钟正式报告",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "redirectOutput": true,
            "justMyCode": true,
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8"
            },
            "args": [
                "report",
                "--data",
                "data/processed/1810_hk_15m.csv",
                "--symbol",
                "1810.HK",
                "--interval",
                "15m"
            ]
        }
    ]
}
