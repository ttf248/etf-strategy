{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "启动 API 服务",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8"
            },
            "args": [
                "api",
                "--host",
                "127.0.0.1",
                "--port",
                "8000"
            ]
        },
        {
            "name": "启动回测 Worker",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8"
            },
            "args": [
                "worker",
                "--poll-interval",
                "5"
            ]
        }
    ]
}
