{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "一键生成指数ETF 1分钟报告",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8"
            },
            "args": [
                "batch",
                "--symbol-set",
                "index_grid_etfs",
                "--strategy",
                "minute_index_grid_retrace",
                "--download",
                "--interval",
                "1m",
                "--period",
                "60d",
                "--proxy",
                "http://127.0.0.1:7897",
                "--jobs",
                "auto",
                "--cache-dir",
                "outputs/cache/index_grid_1m",
                "--output-dir",
                "outputs/index_grid",
                "--report-dir",
                "reports",
                "--execution-profile",
                "realistic"
            ]
        },
        {
            "name": "一键生成1810分钟多策略报告",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1",
                "PYTHONIOENCODING": "utf-8"
            },
            "args": [
                "report",
                "--data",
                "data/processed/1810_hk_15m.csv",
                "--symbol",
                "1810.HK",
                "--interval",
                "15m",
                "--compare-strategies",
                "--jobs",
                "auto",
                "--cache-dir",
                "outputs/cache/minute_compare",
                "--output-dir",
                "outputs/compare/minute",
                "--report-dir",
                "reports/1810_hk/minute",
                "--execution-profile",
                "realistic",
                "--strategy",
                "grid"
            ]
        }
    ]
}
